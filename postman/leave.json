		{
			"name": "Employee (Leave)",
			"item": [
				{
					"name": "Get My History",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
						"method": "GET",
						"url": { "raw": "{{base_url}}/api/leave", "host": ["{{base_url}}"], "path": ["api", "leave"] }
					}
				},
				{
					"name": "Apply Leave (Upload)",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{ "key": "startDate", "value": "2026-04-10", "type": "text" },
								{ "key": "endDate", "value": "2026-04-12", "type": "text" },
								{ "key": "reason", "value": "Mudik ke Tasik", "type": "text" },
								{ "key": "attachment", "type": "file", "src": [] }
							]
						},
						"url": { "raw": "{{base_url}}/api/leave", "host": ["{{base_url}}"], "path": ["api", "leave"] }
					}
				}
			]
		},
		{
			"name": "Admin (Management)",
			"item": [
				{
					"name": "Get All Requests",
					"request": {
