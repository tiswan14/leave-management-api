					}
				},
				{
					"name": "Approve/Reject Leave",
					"request": {
						"auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
						"method": "PATCH",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"approved\",\n    \"rejectReason\": null\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{base_url}}/api/admin/leave/1", "host": ["{{base_url}}"], "path": ["api", "admin", "leave", "1"] }
